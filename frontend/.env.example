# ============================================
# IELTS Web — Environment Variables
# ============================================
# Copy this file to .env and update with your values:
#   cp .env.example .env
#
# All client-side variables MUST be prefixed with VITE_
# See: https://vitejs.dev/guide/env-and-mode

# ---------- API ----------
# Backend API base URL (no trailing slash).
# If unset, api.ts falls back to the placeholder below.
# ⚠️  No real backend exists at this URL — it is a placeholder.
#     All current data comes from bundled mock data in src/data/.
VITE_API_URL=https://api.ieltsweb.com
